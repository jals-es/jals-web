# Allow access to sitemap and robots
<Files sitemap.xml>
  Require all granted
</Files>

<Files robots.txt>
  Require all granted
</Files>

# Ensure correct MIME type for XML
AddType application/xml .xml

# Security headers
Header set X-Content-Type-Options "nosniff" env=!no-header
Header set X-Frame-Options "SAMEORIGIN" env=!no-header
Header set Referrer-Policy "strict-origin-when-cross-origin" env=!no-header

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|png|jpg|jpeg|svg|woff2|woff)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>
